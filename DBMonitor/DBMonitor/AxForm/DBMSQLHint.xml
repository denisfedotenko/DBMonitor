    public void init()
    {
        if (!element.args() 
            || !(element.args().caller())
            || !(element.args().caller() is FormRun)
            || !(formHasMethod(element.args().caller(),identifierStr(getQueryId))))
        {
            throw error(Error::wrongUseOfFunction(funcName()));
        }
        queryId = element.args().caller().getQueryId();

        super();
    }

