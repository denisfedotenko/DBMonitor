}
]]></Source>
			</Method>
			<Method>
				<Name>fillDeterminantComboBox</Name>
				<Source><![CDATA[
    private void fillDeterminantComboBox()
    {
        DBMUpdateStatisticsObjType objType = ObjectType.selection();
        System.Collections.Specialized.StringEnumerator objectEnumerator;
        Set nameSet = new Set(Types::String);
        switch(objType)
        {
            case DBMUpdateStatisticsObjType::Table:
                objectEnumerator = 
                    Microsoft.Dynamics.Ax.Xpp.MetadataSupport::GetDataModelElements(true,false,false,false,false).GetEnumerator();
                break;
            case DBMUpdateStatisticsObjType::View:
                objectEnumerator =
                    Microsoft.Dynamics.Ax.Xpp.MetadataSupport::GetDataModelElements(false,true,false,false,false).GetEnumerator();
                break;
            case DBMUpdateStatisticsObjType::DataEntity:
                objectEnumerator =
                    Microsoft.Dynamics.Ax.Xpp.MetadataSupport::GetDataModelElements(false,false,true,false,false).GetEnumerator();
                break;
            case DBMUpdateStatisticsObjType::Form:
                objectEnumerator =
                    Microsoft.Dynamics.Ax.Xpp.MetadataSupport::FormNames();
                break;
        }
        while (objectEnumerator.MoveNext())
        {
            nameSet.add(objectEnumerator.Current);
        }
        SetEnumerator se = nameSet.getEnumerator();
        determinant.clear();
        while (se.moveNext())
        {
            Determinant.add(se.current());
        }
        element.fillAvailableTables();
    }

]]></Source>
			</Method>
			<Method>
				<Name>fillAvailableTables</Name>
				<Source><![CDATA[
    private void fillAvailableTables()
    {
        DBMUpdateStatisticsObjType objType = ObjectType.selection();
        str objName = determinant.valueStr();
        Set tables = DBMObjectToTableSearcher::construct(objType,objName).search();
        SetEnumerator se = tables.getEnumerator();
        availableTables.clear();
        while (se.moveNext())
        {
            availableTables.add(se.current());
        }
        objectOrigTables = tables;
    }

]]></Source>
			</Method>
			<Method>
				<Name>addTable</Name>
				<Source><![CDATA[
    private void addTable()
    {
        str selectedTable = availableTables.getText(availableTables.selection());
        if (selectedTable && !tablesToUpdateStats.in(selectedTable))
        {
            selectedTables.add(selectedTable);
            tablesToUpdateStats.add(selectedTable);
            availableTables.delete(selectedTable);
        }
    }

]]></Source>
			</Method>
			<Method>
				<Name>removeTable</Name>
				<Source><![CDATA[
    private void removeTable()
    {
        str tableToRemove = selectedTables.getText(selectedTables.selection());
        if (tableToRemove && tablesToUpdateStats.in(tableToRemove))
        {
            if (objectOrigTables.in(tableToRemove))
            {
                availableTables.add(tableToRemove);
            }
            tablesToUpdateStats.remove(tableToRemove);
            selectedTables.delete(tableToRemove);
        }
    }

]]></Source>
			</Method>
			<Method>
				<Name>addAllTables</Name>
				<Source><![CDATA[
    private void addAllTables()
    {
        SetEnumerator se = objectOrigTables.getEnumerator();
        while (se.moveNext())
        {
            if (!tablesToUpdateStats.in(se.current()))
            {
                tablesToUpdateStats.add(se.current());
                selectedTables.add(se.current());
            }
        }
        availableTables.clear();
    }

]]></Source>
			</Method>
			<Method>
				<Name>removeAllTables</Name>
				<Source><![CDATA[
    private void removeAllTables()
    {
        SetEnumerator se = tablesToUpdateStats.getEnumerator();
        while (se.moveNext())
        {
            if (objectOrigTables.in(se.current()))
            {
                availableTables.add(se.current());
            }

        }
        selectedTables.clear();
        tablesToUpdateStats = new Set(Types::String);
    }

]]></Source>
			</Method>
			<Method>
				<Name>init</Name>
				<Source><![CDATA[
    public void init()
    {
        if (!element.args().caller())
        {
            throw error("@SYS22539");
        }

        if (!(element.args().caller() is SysOperationDialog))
        {
            throw error(strFmt("@SYS86720", this.form().name(), classStr(SysOperationDialog)));
        }

        SysOperationDialog sysOperationDialog = element.args().caller() as SysOperationDialog;

        if (sysOperationDialog.controller() == null || !(sysOperationDialog.controller() is DBMUpdateTableStatisticsController))
        {
            throw error(strFmt("@CashManagement:IncorrectControllerType", classStr(DBMUpdateTableStatisticsController)));
        }

        controller = sysOperationDialog.controller() as DBMUpdateTableStatisticsController;

        contract = controller.getDataContractObject(identifierStr(_contract)) as DBMUpdateTableStatisticsContract;

        if (contract == null)
        {
            throw error(strFmt("@CashManagement:IncorrectDataContractType", classStr(DBMUpdateTableStatisticsContract)));
        }
        objectOrigTables = new Set(Types::String);
        super();
        element.fillDeterminantComboBox();
        Determinant.selection(0);
        this.initControlValuesFromContract();
    }

]]></Source>
			</Method>
			<Method>
				<Name>initControlValuesFromContract</Name>
				<Source><![CDATA[
    private void initControlValuesFromContract()
    {
        tablesToUpdateStats = contract.parmTables();
        SetEnumerator se = tablesToUpdateStats.getEnumerator();
        selectedTables.clear();
        while (se.moveNext())
        {
            selectedTables.add(se.current());
        }
    }

]]></Source>
