				<Type>Button</Type>
				<Methods>
					<Method>
						<Name>clicked</Name>
						<Source><![CDATA[
        /// <summary>
        ///
        /// </summary>
        public void clicked()
        {
            super();
            Filename fileName = strFmt('QPL%1.sqlplan', DBMSQLActiveQueries.QueryPlanHash);
            XML LivePlan = DBMSQLUtils::getLiveQueryPlan(DBMSQLActiveQueries.SessionId);
            if (strLen(LivePlan) != 0)
            {
                File::SendStringAsFileToUser(LivePlan, fileName);
            }
        }

]]></Source>
