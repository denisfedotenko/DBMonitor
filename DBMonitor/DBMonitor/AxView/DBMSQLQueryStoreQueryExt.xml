				<Name>isEnabledForAPRC</Name>
				<Source><![CDATA[
    private static str isEnabledForAPRC()
    {
        return SysComputedColumn::if(
            SysComputedColumn::isNotNullExpression(
                SysComputedColumn::comparisonField(viewStr(DBMSQLQueryStoreQueryExt),
                    identifierStr(DBMIsQueryEnabledForAPRC),
                    FieldStr(DBMIsQueryEnabledForAPRC,OptionValue))),
                SysComputedColumn::if(
                    SysComputedColumn::compareExpressions(
                            SysComputedColumn::comparisonField(viewStr(DBMSQLQueryStoreQueryExt),
                            identifierStr(DBMIsQueryEnabledForAPRC),
                            FieldStr(DBMIsQueryEnabledForAPRC,OptionValue)),
                            '=',
                            SysComputedColumn::comparisonLiteral('ON')),
                    SysComputedColumn::returnLiteral(NoYes::Yes),
                    SysComputedColumn::returnLiteral(NoYes::No)),
                SysComputedColumn::returnLiteral(NoYes::No));
    }

]]></Source>
